<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--__________ PRC Abilities __________-->

	<!-- Chinese Stealth Field -->

	<AbilityDef>
		<defName>FCP_Ability_PRC_Stealth_Field</defName>
		<label>stealth field</label>
		<description>Activate the Chinese stealth suit's advanced cloaking technology to become nearly invisible. The light-bending field distorts the wearer's outline, making them extremely difficult to detect. Lasts for a short duration before requiring a recharge.</description>
		<iconPath>UI/Abilities/Invisibility</iconPath>
		<cooldownTicksRange>180000</cooldownTicksRange> <!-- 3 minutes (180 seconds) -->
		<aiCanUse>true</aiCanUse>
		<ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
		<hostile>false</hostile>
		<targetRequired>false</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<statBases>
			<Ability_Duration>15</Ability_Duration>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
			<nonInterruptingSelfCast>true</nonInterruptingSelfCast>
			<warmupTime>0.5</warmupTime>
			<range>0</range>
			<targetable>false</targetable>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>PsychicInvisibility</hediffDef>
			</li>
		</comps>
	</AbilityDef>

</Defs>
