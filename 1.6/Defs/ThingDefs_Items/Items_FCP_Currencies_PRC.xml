<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--__________ Currencies __________-->

	<!-- Chinese Yuan -->

	<ThingDef ParentName="ResourceBase">
		<defName>FCP_Currency_PRC_Yuan</defName>
		<label>Chinese Yuan</label>
		<description>Pre-war Chinese currency, issued by the People's Republic of China. These crisp red banknotes feature the portrait of Chairman Mao and various symbols of communist pride. Despite the passage of centuries since the Great War, yuan notes remain a recognized medium of exchange in regions influenced by Chinese culture and among traders who deal with remnants of the former People's Republic.</description>
		<graphicData>
			<texPath>Things/Items/Currencies/FCP_Chinese_Yuan_Currency</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<resourceReadoutPriority>First</resourceReadoutPriority>
		<soundInteract>Silver_Drop</soundInteract>
		<soundDrop>Silver_Drop</soundDrop>
		<useHitPoints>false</useHitPoints>
		<healthAffectsPrice>false</healthAffectsPrice>
		<resourceReadoutAlwaysShow>true</resourceReadoutAlwaysShow>
		<statBases>
			<RoyalFavorValue>0.0008</RoyalFavorValue>
			<MarketValue>0.15</MarketValue>
			<Mass>0.002</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<thingCategories>
			<li>FCP_Currencies_PRC</li>
		</thingCategories>
		<stackLimit>10000</stackLimit>
		<smallVolume>true</smallVolume>
		<allowedArchonexusCount>1000</allowedArchonexusCount>
		<possessionCount>40</possessionCount>
	</ThingDef>

</Defs>
