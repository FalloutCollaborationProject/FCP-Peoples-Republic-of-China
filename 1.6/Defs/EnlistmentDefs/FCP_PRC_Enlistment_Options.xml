<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Enlistments with Factions __________-->

    <!--_____ People's Republic of China _____-->

    <FCP.Enlist.FactionEnlistOptionsDef>
        <defName>FCP_Enlistment_PRC</defName>
        <minGoodwillRequrementToEnlist>10</minGoodwillRequrementToEnlist>
        <enlistGoodwillGain>5</enlistGoodwillGain>

        <!-- Enlistment Options -->

        <enlistLetterTitleKey>FCP_PRC_Enlist_Letter_Title</enlistLetterTitleKey>
        <enlistLetterLabelKey>FCP_PRC_Enlist_Letter_Label</enlistLetterLabelKey>
        <enlistButtonLabelKey>FCP_PRC_Enlist_Button_Label</enlistButtonLabelKey>
        <enlistButtonDescKey>FCP_PRC_Enlist_Button_Desc</enlistButtonDescKey>
        <enlistRequrementsNotSatisfiedKey>FCP_PRC_Enlist_Requrements_Not_Satisfied</enlistRequrementsNotSatisfiedKey>
        <enlistedToHostileFactionKey>FCP_PRC_Enlisted_To_Hostile_Faction</enlistedToHostileFactionKey>
        <enlistButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Enlist</enlistButtonIconTexPath>
        <enlistedSoundDef>FCP_Sound_Card_Use</enlistedSoundDef>
        <enlistedWithKey>FCP_PRC_Enlisted_With_Key</enlistedWithKey>

        <!-- Mission Options -->

        <missionsAreEnabled>true</missionsAreEnabled>
        <missionsLabelKey>FCP_PRC_Missions_Label</missionsLabelKey>
        <missionsDescKey>FCP_PRC_Missions_Desc</missionsDescKey>
        <missionsButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Missions</missionsButtonIconTexPath>
        <missionsBackgroundMenuTexPath>Things/UI/Enlisted/FCP_PRC_Missions</missionsBackgroundMenuTexPath>
        <missionsMenuDescriptionKey>FCP_PRC_Menu_Missions_Desc</missionsMenuDescriptionKey>
        <missionsMenuSelectQuestKey>FCP_PRC_Menu_Missions_Select_Quest</missionsMenuSelectQuestKey>
        <missionsMenuStartQuestKey>FCP_PRC_Menu_Missions_Start_Quest</missionsMenuStartQuestKey>
        <missionsQuestCost>50</missionsQuestCost>
        <missionsMenuStartQuestNoEnoughMoneyKey>FCP_PRC_Not_Enough_Money</missionsMenuStartQuestNoEnoughMoneyKey>

        <!-- Salary Options -->

        <salaryIsEnabled>true</salaryIsEnabled>
        <salaryDef>FCP_Currency_PRC_Yuan</salaryDef>
        <salaryLabelKey>FCP_PRC_Salary_Label</salaryLabelKey>
        <salaryDescKey>FCP_PRC_Salary_Desc</salaryDescKey>
        <salaryButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Salary</salaryButtonIconTexPath>
        <salaryRange>12000~25000</salaryRange>
        <salaryPeriodDays>14</salaryPeriodDays>

        <!-- Provision Options -->

        <!-- Storage Options -->

        <storageIsEnabled>true</storageIsEnabled>
        <storageLabelKey>FCP_PRC_Storage_Label</storageLabelKey>
        <storageDescKey>FCP_PRC_Storage_Desc</storageDescKey>
        <storageButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Storage</storageButtonIconTexPath>

        <!-- Work Options -->

        <recreationGainPerTick>0.0001</recreationGainPerTick>
        <workOptions>
            <li>
                <workLabelKey>FCP_PRC_Hospital_Label</workLabelKey>
                <workDescKey>FCP_PRC_Hospital_Desc</workDescKey>
                <workButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Hospital</workButtonIconTexPath>
                <additionalRestFall>0.25</additionalRestFall>
                <tendCaravanMembersEveryTicks>600</tendCaravanMembersEveryTicks>
                <medicinesToTend>
                    <li>MedicineIndustrial</li>
                </medicinesToTend>
                <immunityGainSpeedMultiplier>2</immunityGainSpeedMultiplier>
            </li>
            <li>
                <workLabelKey>FCP_PRC_Medical_Training_Label</workLabelKey>
                <workDescKey>FCP_PRC_Medical_Training_Desc</workDescKey>
                <workButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Training_Care</workButtonIconTexPath>
                <experienceGainsPerHour>
                    <Medicine>300</Medicine>
                </experienceGainsPerHour>
                <additionalRestFall>0.25</additionalRestFall>
            </li>
            <li>
                <workLabelKey>FCP_PRC_Shooting_Training_Label</workLabelKey>
                <workDescKey>FCP_PRC_Shooting_Training_Desc</workDescKey>
                <workButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Training_Combat</workButtonIconTexPath>
                <experienceGainsPerHour>
                    <Shooting>300</Shooting>
                </experienceGainsPerHour>
                <additionalRestFall>0.3</additionalRestFall>
            </li>
            <li>
                <workLabelKey>FCP_PRC_Survival_Training_Label</workLabelKey>
                <workDescKey>FCP_PRC_Survival_Training_Desc</workDescKey>
                <workButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Survival_Training</workButtonIconTexPath>
                <experienceGainsPerHour>
                    <Construction>400</Construction>
                    <Cooking>400</Cooking>
                    <Crafting>550</Crafting>
                    <Plants>250</Plants>
                </experienceGainsPerHour>
                <additionalRestFall>0.5</additionalRestFall>
            </li>
        </workOptions>

        <!-- Bounty Options -->

        <turnInIsEnabled>true</turnInIsEnabled>
        <turnInLabelKey>FCP_PRC_Turn_In_Label</turnInLabelKey>
        <turnInDescKey>FCP_PRC_Turn_In_Desc</turnInDescKey>
        <turnInButtonIconTexPath>Things/UI/Enlisted/FCP_Turn_In</turnInButtonIconTexPath>
        <turnInTraderKind>FCP_Caravan_PRC_Prisoner_Exchange</turnInTraderKind>
        <turnInThought>FCP_PRC_Turned_In_A_Spy</turnInThought>
        <turnInRefreshSilverInDays>7</turnInRefreshSilverInDays>
        <turnInTraderNameKey>FCP_PRC_Turn_In_Trader_Name</turnInTraderNameKey>

        <!-- Drop Pod Options -->

        <dropPodServiceIsEnabled>false</dropPodServiceIsEnabled>

        <!-- Resign Options -->

        <resignGoodwillGain>-25</resignGoodwillGain>
        <resignMenuTextKey>FCP_PRC_Resign_Menu_Text</resignMenuTextKey>
        <resignLetterTitleKey>FCP_PRC_Resign_Letter_Title</resignLetterTitleKey>
        <resignLetterLabelKey>FCP_PRC_Resign_Letter_Label</resignLetterLabelKey>
        <resignButtonLabelKey>FCP_PRC_Resign_Button_Label</resignButtonLabelKey>
        <resignButtonDescKey>FCP_PRC_Resign_Button_Desc</resignButtonDescKey>
        <resignButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Resign</resignButtonIconTexPath>

        <!-- Kicked Out Options -->

        <kickOutLetterTitleKey>FCP_PRC_Kick_Out_Letter_Title</kickOutLetterTitleKey>
        <kickOutLetterLabelKey>FCP_PRC_Kick_Out_Label_Title</kickOutLetterLabelKey>

        <!-- Reinforcements Options -->

        <reinforcementsAreEnabled>true</reinforcementsAreEnabled>
        <reinforcementsButtonLabelKey>FCP_PRC_Reinforcements_Button_Label</reinforcementsButtonLabelKey>
        <reinforcementsButtonDescKey>FCP_PRC_Reinforcements_Button_Desc</reinforcementsButtonDescKey>
        <reinforcementsButtonIconTexPath>Things/UI/Enlisted/FCP_PRC_Call_Reinforcements</reinforcementsButtonIconTexPath>
        <reinforcementCallGoodwillCost>-5</reinforcementCallGoodwillCost>
        <reinforcementCallCooldownTicks>50000</reinforcementCallCooldownTicks>
        <reinforcementOptions>
            <li>
                <relationsRange>75~100</relationsRange>
                <pointsRange>800~1800</pointsRange>
            </li>
            <li>
                <relationsRange>50~74</relationsRange>
                <pointsRange>600~850</pointsRange>
            </li>
            <li>
                <relationsRange>26~49</relationsRange>
                <pointsRange>400~600</pointsRange>
            </li>
            <li>
                <relationsRange>-100~25</relationsRange>
                <pointsRange>100~200</pointsRange>
            </li>
        </reinforcementOptions>

    </FCP.Enlist.FactionEnlistOptionsDef>

</Defs>
