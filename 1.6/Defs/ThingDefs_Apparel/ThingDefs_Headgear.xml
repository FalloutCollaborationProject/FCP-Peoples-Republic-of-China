		<recipeMaker>
			<researchPrerequisite>FCP_Research_PRC_Advanced_Equipment</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
		</recipeMaker>
		<graphicData>
			<texPath>Apparel/PRC_Advanced/Chinese_Submariner/FCP_PRC_Submariner_head</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<costList>
			<Cloth>30</Cloth>
			<Plasteel>5</Plasteel>
		</costList>
		<statBases>
			<WorkToMake>4500</WorkToMake>
			<MaxHitPoints>65</MaxHitPoints>
			<Mass>0.3</Mass>
			<ArmorRating_Sharp>0.06</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.04</ArmorRating_Blunt>
			<ArmorRating_Heat>0.03</ArmorRating_Heat>
			<Insulation_Cold>6</Insulation_Cold>
