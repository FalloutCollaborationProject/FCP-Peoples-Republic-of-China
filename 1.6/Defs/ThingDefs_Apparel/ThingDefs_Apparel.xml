				<li>OnSkin</li>
			</layers>
			<tags>
				<li>FCP_PRC_Navy</li>
				<li>FCP_PRC_Naval</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>
		<tradeTags>
			<li>FCP_Trade_Tag_PRC_Apparel</li>
		</tradeTags>
		<comps>
			<li Class="FCP.Core.CompProperties_LabelColored">
				<rarity>Rare</rarity>
			</li>
		</comps>
